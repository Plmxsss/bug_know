# Copy this file to .env for local development. Do not commit the real .env file.
AGRIGUARD_APP_NAME=AgriGuard AI API
AGRIGUARD_APP_SUMMARY=Agricultural pest detection and knowledge API
AGRIGUARD_APP_VERSION=0.1.0
AGRIGUARD_ENVIRONMENT=development
AGRIGUARD_LOG_LEVEL=INFO

# YOLO is optional for API-only development. Enable it after installing [ml].
AGRIGUARD_YOLO_ENABLED=false
AGRIGUARD_YOLO_MODEL_NAME=ip102-yolo26n
AGRIGUARD_YOLO_MODEL_VERSION=1.0.0
AGRIGUARD_YOLO_WEIGHTS_PATH=data/runs/yolo26n_bug_know-5/weights/best.pt
AGRIGUARD_YOLO_CLASS_COUNT=102
AGRIGUARD_YOLO_IMAGE_SIZE=640
AGRIGUARD_YOLO_DEVICE=0
AGRIGUARD_YOLO_CONFIDENCE=0.25

# Uploaded image safety limits and local runtime storage.
AGRIGUARD_MAX_UPLOAD_BYTES=10485760
AGRIGUARD_MAX_IMAGE_PIXELS=25000000
AGRIGUARD_MAX_DOCUMENT_BYTES=20971520
AGRIGUARD_STORAGE_DIR=storage

# Local MySQL container. Replace these example passwords in your private .env file.
AGRIGUARD_MYSQL_HOST=127.0.0.1
AGRIGUARD_MYSQL_DATABASE=agriguard
AGRIGUARD_MYSQL_USER=agriguard
AGRIGUARD_MYSQL_PASSWORD=replace-with-a-local-password
AGRIGUARD_MYSQL_ROOT_PASSWORD=replace-with-a-different-root-password
AGRIGUARD_MYSQL_PORT=3306

# Local Qdrant. The development container is bound only for local use.
AGRIGUARD_QDRANT_URL=http://127.0.0.1:6333
AGRIGUARD_QDRANT_HTTP_PORT=6333
AGRIGUARD_QDRANT_GRPC_PORT=6334
AGRIGUARD_QDRANT_COLLECTION=agriguard_knowledge
AGRIGUARD_RAG_CHUNK_SIZE=800
AGRIGUARD_RAG_CHUNK_OVERLAP=120
AGRIGUARD_RAG_TOP_K=6
AGRIGUARD_EMBEDDING_ENABLED=false
AGRIGUARD_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
AGRIGUARD_EMBEDDING_DEVICE=cpu
AGRIGUARD_EMBEDDING_DIMENSION=512
AGRIGUARD_EMBEDDING_BATCH_SIZE=16
AGRIGUARD_EMBEDDING_CACHE_DIR=models/embeddings

# One OpenAI-compatible interface supports local Ollama or an explicit cloud API.
# Local failure never triggers an automatic cloud fallback.
AGRIGUARD_LLM_ENABLED=false
AGRIGUARD_LLM_PROVIDER=ollama
AGRIGUARD_LLM_BASE_URL=http://127.0.0.1:11434/v1
AGRIGUARD_LLM_API_KEY=
AGRIGUARD_LLM_MODEL=qwen3:4b-instruct-2507-q4_K_M
AGRIGUARD_LLM_STRUCTURED_MODE=json_schema
AGRIGUARD_LLM_TIMEOUT_SECONDS=120
AGRIGUARD_LLM_MAX_RETRIES=2
AGRIGUARD_LLM_TEMPERATURE=0
AGRIGUARD_LLM_MAX_TOKENS=2048
